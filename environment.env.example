# Copy to environment.env and fill in. The real environment.env is gitignored.
# Scripts auto-load it via loadenv.py.

SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...        # server-side key (bypasses RLS) — worker only
HOOKED_OWNER_ID=                          # optional: a user's auth uid to scope their feed

YT_API_KEY=                               # YouTube Data API v3 key
GEMINI_API_KEY=                           # Gemini API key (enable billing for paid TTS)

# Web app (publishable key is client-safe; also goes in webapp/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
